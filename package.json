    "@prisma/client": "^5.14.0",
    "amqplib": "^0.10.4",
    "dompurify": "^3.1.5",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.1",
    "jsdom": "^24.1.0",
