// prisma/schema.prisma
// Database: PostgreSQL
// ORM: Prisma 5

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────

enum PostStatus {
  DRAFT
  REVIEW       // awaiting editorial approval
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
  DELETED
}

enum ReactionType {
  LIKE
  BOOKMARK
  SHARE
}

enum SubscriptionStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

// ─────────────────────────────────────────────────────────────────────
// Author profile (mirrors partial data from Auth service)
// Kept lightweight — source of truth is the Auth/User service.
// Synced via RabbitMQ events when user profile changes.
// ─────────────────────────────────────────────────────────────────────

model Author {
  id          String   @id               // same UUID as in Auth service
  displayName String
  avatarUrl   String?
  bio         String?
  school      String?
  role        String?
  twitterHandle String?
  gradient    String?  // Tailwind gradient, e.g. "from-blue-600 to-indigo-600"
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       Post[]

  @@map("authors")
}

// ─────────────────────────────────────────────────────────────────────
// Category
// ─────────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  seoDescription String?
  coverGradient  String?
  emoji          String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       Post[]

  @@map("categories")
}

// ─────────────────────────────────────────────────────────────────────
// Tag
// ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  posts     PostTag[]

  @@map("tags")
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ─────────────────────────────────────────────────────────────────────
// Post
// ─────────────────────────────────────────────────────────────────────

model Post {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  excerpt         String
  content         String     // Markdown source
  contentHtml     String?    // Pre-rendered HTML (cached at write time)
  coverEmoji      String?
  coverImageUrl   String?
  coverGradient   String?
  featured        Boolean    @default(false)
  status          PostStatus @default(DRAFT)
  readTimeMinutes Int        @default(0)

  // SEO overrides
  seoTitle       String?
  seoDescription String?
  ogImageUrl     String?

  // Publish scheduling
  publishedAt    DateTime?
  scheduledAt    DateTime?

  // Stats — denormalised counters (updated async via event queue)
  viewCount      Int @default(0)
  likeCount      Int @default(0)
  commentCount   Int @default(0)
  shareCount     Int @default(0)
  bookmarkCount  Int @default(0)

  // Relations
  authorId    String
  author      Author   @relation(fields: [authorId], references: [id])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  tags        PostTag[]
  comments    Comment[]
  reactions   PostReaction[]
  revisions   PostRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@index([categoryId, status])
  @@index([authorId])
  @@index([featured, status])
  @@map("posts")
}

// ─────────────────────────────────────────────────────────────────────
// Post revision history (audit trail)
// ─────────────────────────────────────────────────────────────────────

model PostRevision {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  title     String
  content   String
  editedBy  String   // author or editor userId
  note      String?  // e.g. "Fixed typos", "Updated scholarship deadline"
  createdAt DateTime @default(now())

  @@index([postId, createdAt(sort: Desc)])
  @@map("post_revisions")
}

// ─────────────────────────────────────────────────────────────────────
// Comment (threaded, 2 levels: top-level + replies)
// ─────────────────────────────────────────────────────────────────────

model Comment {
  id          String        @id @default(cuid())
  postId      String
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String?       // null for guest comments
  parentId    String?       // null = top-level; set = reply
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]     @relation("CommentReplies")
  body        String
  status      CommentStatus @default(PENDING)
  likeCount   Int           @default(0)
  // Guest commenter fields (populated when authorId is null)
  guestName   String?
  guestEmail  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([postId, status, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("comments")
}

// ─────────────────────────────────────────────────────────────────────
// Post reactions (like, bookmark, share — one per user per type)
// ─────────────────────────────────────────────────────────────────────

model PostReaction {
  postId   String
  userId   String
  type     ReactionType
  post     Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@id([postId, userId, type])
  @@index([userId])
  @@map("post_reactions")
}

// ─────────────────────────────────────────────────────────────────────
// Newsletter subscribers
// ─────────────────────────────────────────────────────────────────────

model NewsletterSubscriber {
  id          String             @id @default(cuid())
  email       String             @unique
  firstName   String?
  status      SubscriptionStatus @default(ACTIVE)
  categories  String[]           // array of category slugs
  token       String             @unique @default(cuid()) // unsubscribe/verify token
  verifiedAt  DateTime?
  subscribedAt DateTime          @default(now())
  unsubscribedAt DateTime?

  @@index([status])
  @@map("newsletter_subscribers")
}

// ─────────────────────────────────────────────────────────────────────
// Post view log (deduped by IP + post per hour for analytics)
// ─────────────────────────────────────────────────────────────────────

model PostView {
  id        String   @id @default(cuid())
  postId    String
  userId    String?  // null = anonymous
  ipHash    String   // SHA-256 of IP — no raw PII stored
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([postId, createdAt(sort: Desc)])
  @@map("post_views")
}
