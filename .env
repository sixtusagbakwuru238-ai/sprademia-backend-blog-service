# # DATABASE_URL=postgresql://blog_admin:9vFK2mQx7pL4zT8wR6cN3bY@postgres:5432/sprademia_blog_postgres
# DATABASE_URL=postgresql://blog_admin:9vFK2mQx7pL4zT8wR6cN3bY@localhost:5432/sprademia_blog
# REDIS_URL=redis://localhost:6379
# RABBITMQ_URL=amqp://localhost:5672
# JWT_SECRET=9f8c2b1a6e4d3c7f5a9b0e1d2c4f6a8b7d9e0f1c2b3a4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9
# INTERNAL_API_KEY=sk_internal_6YpQ3m9XvKfT2Lr8JcH5Wz0aN1uD7BqE4sGxP9tR



# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
SERVICE_NAME=blog-service

# ── Database (PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://blog_admin:9vFK2mQx7pL4zT8wR6cN3bY@localhost:5432/sprademia_blog

# ── Redis (caching + rate limiting) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── RabbitMQ (inter-service events) ──────────────────────────────────
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE="sprademia.events"

# ── JWT (validated here, issued by Auth service) ──────────────────────
# Must match the secret used by the Auth service
JWT_SECRET=9f8c2b1a6e4d3c7f5a9b0e1d2c4f6a8b7d9e0f1c2b3a4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9

# ── API Gateway / Internal Auth ───────────────────────────────────────
# Shared secret for internal service-to-service calls
INTERNAL_API_KEY=sk_internal_6YpQ3m9XvKfT2Lr8JcH5Wz0aN1uD7BqE4sGxP9tR

# ── Cache TTLs (seconds) ──────────────────────────────────────────────
CACHE_TTL_POSTS=300        # 5 min — list pages
CACHE_TTL_POST=600         # 10 min — individual posts
CACHE_TTL_CATEGORIES=3600  # 1 hour — rarely change
CACHE_TTL_TAGS=1800        # 30 min

# ── Rate limiting ─────────────────────────────────────────────────────
RATE_LIMIT_MAX=120          # requests per window
RATE_LIMIT_WINDOW=60000     # 1 minute in ms

# ── Content ───────────────────────────────────────────────────────────
MAX_CONTENT_LENGTH_MB=5
ALLOWED_IMAGE_HOSTS="res.cloudinary.com,imagedelivery.net,sprademia.ng"

# ── Pagination ────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=12
MAX_PAGE_SIZE=200

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Cors ─────────────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:3002,https://sprademia.ng,https://www.sprademia.ng"
